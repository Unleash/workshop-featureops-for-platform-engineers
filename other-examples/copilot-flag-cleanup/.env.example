# Local config for the webhook register/unregister scripts (other-examples/copilot-flag-cleanup).
# Copy to `.env` in this directory: `cp .env.example .env`. The root `.env.example` is untouched.

# Shared with the root .env / Terraform / unleash-provisioner — paste the SAME values.
# Admin base URL (everything before /api) and an admin Service Account token or PAT.
TF_VAR_unleash_base_url=https://<your-unleash-instance>
TF_VAR_unleash_token=<admin service-account token / PAT>

# Example-specific — where the cleanup issues are opened.
GITHUB_REPO=<OWNER/REPO>
GITHUB_TOKEN=<token with issues:write on that repo>

# NOTE: the MCP server URL + PAT the Copilot cloud agent uses (UNLEASH_MCP_SERVER_URL,
# UNLEASH_MCP_PAT_TOKEN) are configured in the GitHub Copilot environment, NOT in this file —
# see copilot/mcp.json and the README.
