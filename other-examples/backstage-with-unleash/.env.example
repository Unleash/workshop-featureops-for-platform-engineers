# Local config for the Backstage and Unleash integration example (other-examples/backstage-with-unleash).
# Copy to `.env` in this directory: `cp .env.example .env`. The root `.env.example` is untouched.

# Unleash instance BASE url, WITHOUT a trailing /api. The plugin appends /api/admin/... itself.
# Example for the workshop cloud instance:
UNLEASH_URL=

# Unleash service-account token used by the Backstage Unleash plugin (read-only Viewer is enough).
# Provisioned by support/infrastructure/terraform — read it with:
#   terraform -chdir=../../support/infrastructure/terraform output -raw backstage_unleash_token
UNLEASH_API_TOKEN=
