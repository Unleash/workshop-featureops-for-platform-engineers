# Dependencies:
node_modules/
.pnpm-store/
# Generated only when falling back to npm (no pnpm); pnpm-lock.yaml stays canonical.
package-lock.json

# Build output:
dist/
*.tsbuildinfo

# Environment variables & secrets (only `.env.example` is committed):
.env
.env.local
.env.*.local

# Master kill switch signal URL + token, written by the provisioner for the sender:
.master-kill-switch.json

# Terraform state & local artifacts:
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# Test and coverage assets:
coverage/

# Logs and assets:
docs/development.md
*.csv
*.log

# OS cruft, Agents, VCS, IDEs, editors:
.DS_Store
.idea/
.vscode/*
.claude/worktrees/*
!.claude/settings.local.json

# Ignore VS Code settings, but commit the shared MCP server template.
!.vscode/mcp.json
