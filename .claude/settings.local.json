{
  "enabledMcpjsonServers": [
    "unleash"
  ],
  "permissions": {
    "allow": [
      "mcp__unleash__get_flag_state",
      "mcp__unleash__evaluate_change",
      "mcp__unleash__detect_flag",
      "mcp__unleash__create_flag",
      "mcp__unleash__wrap_change",
      "mcp__unleash__set_flag_rollout",
      "mcp__unleash__toggle_flag_environment",
      "mcp__unleash__remove_flag_strategy",
      "mcp__unleash__cleanup_flag"
    ],
    "deny": [
      "Read(.env)",
      "Bash(rm)",
      "Bash(git rm)"
    ]
  }
}
