# -------------------------------------------------------------------------------------------------------------
# Single source of truth for environment variables in this repository.
#
# If you don't have `.env` yet, run `make ensure-env` to create it based on
# this template.
# -------------------------------------------------------------------------------------------------------------

# -------------------------------------------------------------------------------------------------------------
# Variables that you MUST adjust as any attendee.
#
# The easiest way to fill this whole section is `make workshop-configure`: it asks for your region
# and instance, takes the Personal Access Token (PAT) you create in the Unleash UI, and fills the
# values below for you. The per-variable notes explain each one if you prefer to set them by hand.
# -------------------------------------------------------------------------------------------------------------
# The attendee's project number (NNN) — back-end counterpart of VITE_UNLEASH_PROJECT_NUMBER.
# Prefixes the flag + context-field names the API evaluates (pNNN_…). Auto-detected by
# `make workshop-configure` (the project you own); or set it to your assigned number (e.g. `001`).
VITE_UNLEASH_PROJECT_NUMBER=
UNLEASH_PROJECT_NUMBER=

# Cloud Unleash Frontend + admin API URLs. Filled by `make workshop-configure` from your region +
# instance, e.g. https://<region>.app.unleash-hosted.com/<instance>/api/frontend/ and .../api/ .
VITE_UNLEASH_URL=
UNLEASH_URL=

# A development and a production application run side by side (shared cloud Unleash instance,
# one SDK token per environment). The generic *_CLIENT_KEY / *_API_TOKEN below are the
# DEVELOPMENT tokens; the *_PRODUCTION variants drive the production instance. Filled by
# `make workshop-configure` (it reads them from the Unleash API with your PAT).
VITE_UNLEASH_CLIENT_KEY=
UNLEASH_API_TOKEN=
VITE_UNLEASH_CLIENT_KEY_PRODUCTION=
UNLEASH_API_TOKEN_PRODUCTION=

# Your Personal Access Token (PAT), created in the Unleash UI at
# https://<region>.app.unleash-hosted.com/<instance>/profile/personal-api-tokens .
# `make workshop-configure` writes it here and uses it to fetch the tokens above; `make
# workshop-final-check` uses it to authenticate. Same value as UNLEASH_MCP_PAT_TOKEN below.
UNLEASH_PAT=

# -------------------------------------------------------------------------------------------------------------
# Unleash MCP server to use with AI coding assistant: Claude Code, Codex, Copilot, Kiro, OpenCode, Cursor, of Gemini
# -------------------------------------------------------------------------------------------------------------
# The committed MCP config templates (`.mcp.json`, `.cursor/mcp.json`, `.vscode/mcp.json`, `.kiro/settings/mcp.json`,
# `opencode.json`, `.codex/config.toml`, `.gemini/settings.json`) read these two values. Remember to export them
# in your shell so the assistant can pick them up, or paste the values directly into your client's config.
# The remote MCP server is the preferred way to connect for this workshop, see the documentation available here:
# https://docs.getunleash.io/integrate/mcp. This is how the remote Unleash MCP URL looks like:
# https://<region>.app.unleash-hosted.com/<instance>/api/admin/mcp - both are filled by `make workshop-configure`
# (the token equals UNLEASH_PAT above); `make workshop-final-check` prints ready-to-copy `export` commands for
# the shell your assistant uses.
UNLEASH_MCP_SERVER_URL=
UNLEASH_MCP_PAT_TOKEN=

# -------------------------------------------------------------------------------------------------------------
# Variables that you MUST adjust only if you are a maintainer or self-paced workshop user.
# -------------------------------------------------------------------------------------------------------------
# Terraform provisioning used by `make unleash-create` / `make unleash-destroy` requires cloud-based Unleash
# base URL (everything before `/api`).
TF_VAR_unleash_base_url=
# Token used by Terraform for provisioning. The recommended way is to create a dedicated Service Account token for
# Terraform or use a Personal Access Token (PAT) for the user with the proper permissions.
TF_VAR_unleash_token=
# Facilitator/admin email added to every team group so the group can approve attendees' production
# change requests (attendees cannot approve their own — segregation of duties). Override as needed.
TF_VAR_facilitator_email=wojtek.gawronski@getunleash.io

# -------------------------------------------------------------------------------------------------------------
# Optional configuration knobs.
# -------------------------------------------------------------------------------------------------------------
# Frontend (src/gift-store/storefront) variables baked at build time by Vite (VITE_*).
# App identity slug for the Unleash SDK (mirrors the backend APP_NAME); VITE_TITLE is the display title.
VITE_APP_NAME=gift-store-storefront
VITE_TITLE="Unofficial FeatureOps Gift Store"
VITE_API_URL=http://localhost:8081
# Public base URLs of the payment providers — the chooser loads each provider's hosted brand
# icon (GET /favicon.svg) from here, the way a real integration pulls hosted brand assets.
VITE_PAYBRO_URL=http://localhost:8400
VITE_DASHED_URL=http://localhost:8401
# Demo dev sidebar's INITIAL state (default enabled = starts open). Set to false to start it
# collapsed; the low-contrast reopen handle (top-left) stays available either way.
VITE_DEVTOOLS_ENABLED=true
# Unleash Toolbar visibility on load (default disabled). It can always be revealed live from the
# browser dev console via `window.unleashToolbar.show()`.
VITE_UNLEASH_TOOLBAR_ENABLED=false
# Frontend environment knob (mirrors the backend NODE_ENV): names the environment for the
# SDK/Toolbar + the on-screen ribbon. `production` for the prod stack.
VITE_NODE_ENV=development

# --- Backend (src/gift-store/checkout)
# Single environment knob: `development` drives pretty logs + the PayBro $0.00 sandbox;
# `production` drives JSON logs + real charges. Also names the Unleash SDK environment.
NODE_ENV=development
LOG_LEVEL=info
PORT=8081
APP_NAME=gift-store-api
PUBLIC_WEB_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8081
# Fake payment providers integration settings.
# PayBro routing that is currently hardwired in the application code.
PAYBRO_URL=http://localhost:8400
PAYBRO_WEBHOOK_SECRET=paybro-dev-webhook-secret
# Dashed routing is built but not registered (as that is the workshop exercise). These are ready for when it is.
DASHED_URL=http://localhost:8401
DASHED_WEBHOOK_SECRET=dashed-dev-webhook-secret

# --- PayBro provider (src/payment-providers/paybro).
# PayBro and Dashed are shared by both stacks; kept out of the 808x/809x app-port range to avoid confusion.
PAYBRO_PORT=8400
PAYBRO_PUBLIC_URL=http://localhost:8400
PAYBRO_APP_NAME=paybro

# --- Dashed provider (src/payment-providers/dashed) — modern drop-in alternative, not yet wired to the API.
DASHED_PORT=8401
DASHED_PUBLIC_URL=http://localhost:8401
DASHED_APP_NAME=dashed
